NODE_ENV=development

# Redis — must match what the API connects to
REDIS_URL="redis://localhost:6379"

# Database — worker reads/writes project status
DATABASE_URL="postgresql://postgres:password@localhost:5432/botforge"

# Absolute path on the VPS where bot workspaces are created.
# Each project gets its own subdirectory: {BOT_WORKSPACE_BASE}/{projectId}/
# Must be writable by the user running the worker process.
BOT_WORKSPACE_BASE="/var/botforge/bots"
