NODE_ENV=development
PORT=3001

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/botforge"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"

# Stripe (Layer 2 — not used yet)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Secret encryption (AES-256-GCM for BotSecret storage)
# Generate with: openssl rand -base64 32
BOT_SECRET_ENCRYPTION_KEY=""

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
